# Copy to .env and fill in. .env is gitignored — never commit real credentials.
QUOTEX_EMAIL=
QUOTEX_PASSWORD=

# Account mode. "demo" is the ONLY safe default.
# Setting this to "real" alone is NOT enough — see QUOTEX_ALLOW_REAL below.
QUOTEX_ACCOUNT_MODE=demo

# Deliberate, explicit opt-in required before any real-money order can be sent.
# Must be the exact string: I_UNDERSTAND_REAL_MONEY_RISK
QUOTEX_ALLOW_REAL=

# Risk limits (apply in BOTH demo and real)
RISK_STAKE_PER_TRADE=1.0
RISK_MAX_DAILY_LOSS=10.0
RISK_MAX_TRADES_PER_DAY=20
